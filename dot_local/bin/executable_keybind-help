#!/usr/bin/env bash
hyprctl -j binds | jq -r '.[] | "\(.modmask)|\(.key)|\(.dispatcher)|\(.arg)"' | \
  awk -F'|' '{
    mod=""
    if ($1 == 0) mod=""
    else if ($1 == 64) mod="SUPER"
    else if ($1 == 65) mod="SUPER SHIFT"
    else if ($1 == 68) mod="SUPER CTRL"
    else if ($1 == 69) mod="SUPER CTRL SHIFT"
    else if ($1 == 72) mod="SUPER ALT"
    else if ($1 == 73) mod="SUPER ALT SHIFT"
    else if ($1 == 1) mod="SHIFT"
    else if ($1 == 4) mod="CTRL"
    else if ($1 == 5) mod="CTRL SHIFT"
    else if ($1 == 8) mod="ALT"
    else if ($1 == 12) mod="CTRL ALT"
    else mod="MOD " $1
    key = $2; gsub(/^[ \t]+|[ \t]+$/, "", key)
    action = $3 " " $4; gsub(/^[ \t]+|[ \t]+$/, "", action)
    if (key != "" && action != " ") {
      if (mod != "") printf "%-25s → %s\n", mod " + " key, action
      else printf "%-25s → %s\n", key, action
    }
  }' | sort -u | rofi -dmenu -p 'Keybindings'
